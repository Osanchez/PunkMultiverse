{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageGameObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::punkmultiverse-gamefiles-577792960632-us-east-1/*"
    },
    {
      "Sid": "InspectGameBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutBucketPublicAccessBlock"
      ],
      "Resource": "arn:aws:s3:::punkmultiverse-gamefiles-577792960632-us-east-1"
    }
  ]
}
